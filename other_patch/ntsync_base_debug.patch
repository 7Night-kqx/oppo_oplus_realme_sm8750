+static const char *ntsync_cmd_name(unsigned int cmd)
+{
+	switch (cmd) {
+	case NTSYNC_IOC_CREATE_SEM:    return "CREATE_SEM";
+	case NTSYNC_IOC_CREATE_MUTEX:  return "CREATE_MUTEX";
+	case NTSYNC_IOC_CREATE_EVENT:  return "CREATE_EVENT";
+	case NTSYNC_IOC_WAIT_ANY:      return "WAIT_ANY";
+	case NTSYNC_IOC_WAIT_ALL:      return "WAIT_ALL";
+	case NTSYNC_IOC_SEM_RELEASE:   return "SEM_RELEASE";
+	case NTSYNC_IOC_MUTEX_UNLOCK:  return "MUTEX_UNLOCK";
+	case NTSYNC_IOC_MUTEX_KILL:    return "MUTEX_KILL";
+	case NTSYNC_IOC_EVENT_SET:     return "EVENT_SET";
+	case NTSYNC_IOC_EVENT_RESET:   return "EVENT_RESET";
+	case NTSYNC_IOC_EVENT_PULSE:   return "EVENT_PULSE";
+	default:                       return "UNKNOWN_CMD";
+	}
+}
